# Oh My Coder 环境配置示例
# 复制此文件为 .env 并填入你的 API Keys

# ===========================================
# 必填（至少配置一个）
# ===========================================

# DeepSeek（推荐，免费额度高，每天 4000 万 token）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key

# ===========================================
# 可选：其他模型
# ===========================================

# 文心一言（百度）
# 获取地址: https://console.bce.baidu.com/
WENXIN_API_KEY=your_api_key
WENXIN_SECRET_KEY=your_secret_key

# 通义千问（阿里）
# 获取地址: https://dashscope.console.aliyun.com/
TONGYI_API_KEY=your_api_key

# 智谱 GLM（ChatGLM）
# 获取地址: https://open.bigmodel.cn/
GLM_API_KEY=your_api_key

# MiniMax（海螺）
# 获取地址: https://www.minimaxi.com/
MINIMAX_API_KEY=your_api_key

# Kimi（月暗）
# 获取地址: https://platform.moonshot.cn/
KIMI_API_KEY=your_api_key

# 混元（腾讯）
# 获取地址: https://cloud.tencent.com/
HUNYUAN_API_KEY=your_api_key
HUNYUAN_SECRET_KEY=your_secret_key

# 豆包（字节）
# 获取地址: https://console.volcengine.com/
DOUBAO_API_KEY=your_api_key

# ===========================================
# 使用说明
# ===========================================
# 1. 复制此文件: cp .env.example .env
# 2. 编辑 .env 填入你的 API Keys
# 3. 运行: source .env
# 或直接 export:
#    export DEEPSEEK_API_KEY=your_key
#
# 模型优先级（按性价比排序）:
# DeepSeek > Kimi > 豆包 > MiniMax > GLM > 通义 > 文心 > 混元
